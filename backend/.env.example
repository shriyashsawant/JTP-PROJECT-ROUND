# Local Docker Postgres/pgvector
DATABASE_URL=postgresql://auramatch:auramatch_secret@localhost:5434/auramatch

# ML Model
MODEL_NAME=all-MiniLM-L6-v2

# Optional: enables LLM re-ranking/explanation synthesis on top of the
# deterministic engine (see app/services/llm_enrichment.py). The app works
# fully without this - every call has a strict timeout and falls back to
# the deterministic explanation/ranking on any failure or if this is unset.
GROQ_API_KEY=
